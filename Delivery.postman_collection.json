{
  "info": {
    "name": "ShopeeFood API",
    "_postman_id": "shopeefood-col-001",
    "description": "Complete API collection for ShopeeFood delivery system. Base URL: {{baseUrl}}\n\n**Quick Start:**\n1. Import this collection + the Environment file\n2. Select env \"ShopeeFood Local\"\n3. Run **Auth / Register** or **Auth / Login** → token is saved automatically\n4. All other requests use {{accessToken}} automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "01 - Auth",
      "description": "Register & Login. Token is auto-saved to {{accessToken}} after each call.",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.data && r.data.access_token) {",
                  "    pm.environment.set('accessToken', r.data.access_token);",
                  "    pm.environment.set('userId', r.data.user_id);",
                  "    console.log('Token saved:', r.data.access_token.substring(0,20) + '...');",
                  "}",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has access_token', () => pm.expect(r.data.access_token).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyen Van A\",\n  \"email\": \"user1@gmail.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.data && r.data.access_token) {",
                  "    pm.environment.set('accessToken', r.data.access_token);",
                  "    pm.environment.set('userId', r.data.user_id);",
                  "    console.log('Token saved:', r.data.access_token.substring(0,20) + '...');",
                  "}",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has access_token', () => pm.expect(r.data.access_token).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user1@gmail.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
